<!DOCTYPE html>
<html>
    <head>
        <meta charset="utf-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <title></title>
        <meta name="description" content="">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link  rel="stylesheet"  href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css" />
        <link rel="stylesheet" href="/css/index.css">
        <link rel="stylesheet" href="/css/event.css">
    </head>
    <body>
        <h1><%= event.title %></h1>
        <p><% if (event.date) { %>Event Date: <%= event.date %><% } %></p>
        <p><% if (event.budget) { %>Budget: $<%= event.budget %><% } %></p>
        <p><% if (event.drivers && event.drivers.length > 0) { %>Drivers: <%= event.drivers.join(', ') %><% } %></p>
        <p><% if (event.description) { %>Description: <%= event.description %><% } %></p>
        <a href="/">Back to Events List</a>
        <script src="/js/event.js" async defer></script>
    </body>
</html>